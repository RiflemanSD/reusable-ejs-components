<%
  const itemsList = Array.isArray(items) ? items : [];
  const cols = Array.isArray(columns) ? columns : [];
  const linkCandidates = Array.isArray(linkColumnCandidates) && linkColumnCandidates.length > 0
    ? linkColumnCandidates
    : ['name', 'sku', 'id'];
  const normalizedCandidates = linkCandidates.map((col) => String(col).toLowerCase());
  const basePath = typeof actionBasePath === 'string' ? actionBasePath : '';
  const actionText = actionLabel || 'Άνοιγμα';
  const itemIdentifierKey = typeof identifierKey === 'string' && identifierKey ? identifierKey : 'id';
  const encodedReturnTo = typeof returnTo === 'string' ? returnTo : '';
  const resolvedLinkColumn = cols.find((col) => normalizedCandidates.includes(String(col).toLowerCase()));

  function formatCell(columnName, value) {
    if ((columnName.includes('price') || columnName.includes('cost')) && value !== null && value !== undefined && value !== '' && !isNaN(value)) {
      return `EUR ${parseFloat(value).toFixed(2)}`;
    }
    return value !== null && value !== undefined ? String(value) : '';
  }

  function buildItemUrl(item) {
    const itemIdentifier = item[itemIdentifierKey];
    if (!basePath || itemIdentifier === null || itemIdentifier === undefined) {
      return '';
    }
    const encodedItemId = encodeURIComponent(String(itemIdentifier));
    return encodedReturnTo ? `${basePath}/${encodedItemId}?returnTo=${encodedReturnTo}` : `${basePath}/${encodedItemId}`;
  }
%>

<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <% cols.forEach((col) => { %>
          <th><%= col %></th>
        <% }) %>
        <% if (basePath) { %>
          <th>Ενέργεια</th>
        <% } %>
        <% if (Array.isArray(itemsList) && itemsList.length > 0 && itemsList[0].csvRowNumber !== undefined) { %>
          <th>Μεταφορά</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% itemsList.forEach((item) => {
        const itemUrl = buildItemUrl(item);
      %>
        <tr>
          <% cols.forEach((col) => {
            const cellText = formatCell(col, item[col]);
            const isLinkCol = resolvedLinkColumn && String(col).toLowerCase() === String(resolvedLinkColumn).toLowerCase() && itemUrl;
          %>
            <td>
              <% if (isLinkCol) { %>
                <a href="<%= itemUrl %>" class="link link-primary font-medium"><%= cellText %></a>
              <% } else { %>
                <%= cellText %>
              <% } %>
            </td>
          <% }) %>
          <% if (basePath) { %>
            <td>
              <% if (itemUrl) { %>
                <a href="<%= itemUrl %>" class="btn btn-xs btn-outline btn-primary"><%= actionText %></a>
              <% } %>
            </td>
          <% } %>
          <% if (item.csvRowNumber !== undefined && item.snapshotId) { %>
            <td>
              <form method="POST" action="/protimologia/copy-from-snapshot/<%= item.snapshotId %>" style="display:inline">
                <button type="submit" class="btn btn-xs btn-warning" onclick="return confirm('Να μεταφερθεί το snapshot στη βάση και να ανοίξει για επεξεργασία;')">
                  Μεταφορά & Επεξεργασία
                </button>
              </form>
            </td>
          <% } %>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="text-sm text-gray-600 mt-2">
    📊 <%= Number(totalItems || 0).toLocaleString() %> συνολικά <%= summaryLabel || 'στοιχεία' %> - <%= cols.length %> στήλες
  </div>
</div>